# Renomeie para .env e preencha antes de rodar docker compose up

# Domínio público usado pelo Traefik
APP_DOMAIN=festacomia.pro

# Versão da imagem (padrão: latest)
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_DB=festacomia
POSTGRES_USER=festacomia
POSTGRES_PASSWORD=<senha-forte>

# Redis
REDIS_PASSWORD=<senha-forte>

# URL pública da aplicação
NEXT_PUBLIC_SITE_URL=https://festacomia.pro

# Webhook do n8n
N8N_WEBHOOK_URL=http://n8n:5678/webhook/send-message

# Supabase — usado apenas no backend para exclusão total da conta
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# DATABASE_URL é montada automaticamente pelo docker-compose com as vars acima
# Não precisa definir manualmente aqui — está configurada no serviço web